---
import { commentConfig } from "@/config";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<div id="twikoo-container" class="twikoo-container">
	<div id="tcomment"></div>
</div>

<script is:inline define:vars={{ config }}>
	(function () {
		const TWIKOO_CONTAINER_ID = "twikoo-container";
		const TWIKOO_SCRIPT_URL = "/assets/js/twikoo.all.min.js";
		const ROOT_MARGIN = "200px";
		const GLOBAL_KEY = "__twikoo";

		let twikooLoaded = false;

		function getState() {
			if (!window[GLOBAL_KEY]) {
				window[GLOBAL_KEY] = {
					observer: null,
					swupHooked: false,
					eventsBound: false,
				};
			}
			return window[GLOBAL_KEY];
		}

		function getCurrentPath() {
			const pathname = window.location.pathname;
			return pathname.endsWith("/") && pathname.length > 1
				? pathname.slice(0, -1)
				: pathname;
		}

		function createTwikooConfig() {
			return {
				...config,
				path: getCurrentPath(),
				el: "#tcomment",
			};
		}

		async function loadTwikooScript() {
			if (
				twikooLoaded ||
				document.getElementById("twikoo-script-loaded")
			) {
				return;
			}
			return new Promise((resolve, reject) => {
				const script = document.createElement("script");
				script.id = "twikoo-script-loaded";
				script.src = TWIKOO_SCRIPT_URL;
				script.async = true;
				script.onload = () => {
					twikooLoaded = true;
					resolve();
				};
				script.onerror = reject;
				document.head.appendChild(script);
			});
		}

		async function initTwikoo() {
			const commentEl = document.getElementById("tcomment");
			if (!commentEl) {
				return;
			}

			// Swup 生产模式下 updateHead: true 会在页面切换时替换 <head>，
			// twikoo.all.min.js 注入的 Element UI 样式标签会随之丢失。
			// 此时 window.twikoo 仍然存在，库再次执行时会跳过初始化（从而跳过样式注入）。
			// 删除全局实例，强制库在下次加载时完整重新初始化，确保样式被重新注入。
			if (window.twikoo) {
				delete window.twikoo;
				const oldScript = document.getElementById(
					"twikoo-script-loaded",
				);
				if (oldScript) oldScript.remove();
				twikooLoaded = false;
			}

			try {
				await loadTwikooScript();

				if (typeof twikoo === "undefined") {
					console.warn("[Twikoo] 脚本加载失败");
					return;
				}

				commentEl.innerHTML = "";
				const dynamicConfig = createTwikooConfig();
				await twikoo.init(dynamicConfig);
			} catch (error) {
				console.error("[Twikoo] 初始化失败:", error);
			}
		}

		function cleanup() {
			const state = getState();
			if (state.observer) {
				state.observer.disconnect();
				state.observer = null;
			}
			if (window.swup?.hooks) {
				window.swup.hooks.off("content:replace", initTwikoo);
			}
		}

		function setupLazyLoad() {
			const container = document.getElementById(TWIKOO_CONTAINER_ID);
			if (!container) {
				return;
			}

			const state = getState();

			// Disconnect any existing observer before creating a new one,
			// preventing multiple observers from watching the same element.
			if (state.observer) {
				state.observer.disconnect();
				state.observer = null;
			}

			state.observer = new IntersectionObserver(
				(entries) => {
					if (entries[0]?.isIntersecting && state.observer) {
						state.observer.disconnect();
						state.observer = null;
						initTwikoo();
					}
				},
				{ rootMargin: ROOT_MARGIN },
			);

			state.observer.observe(container);
		}

		function setupSwupHooks() {
			const state = getState();
			if (state.swupHooked) return;
			state.swupHooked = true;

			if (window.swup?.hooks) {
				window.swup.hooks.on("content:replace", () => {
					setTimeout(setupLazyLoad, 200);
				});
			} else {
				document.addEventListener(
					"swup:enable",
					() => {
						if (window.swup?.hooks) {
							window.swup.hooks.on("content:replace", () => {
								setTimeout(setupLazyLoad, 200);
							});
						}
					},
					{ once: true },
				);
			}
		}

		function bindEvents() {
			const state = getState();
			if (state.eventsBound) return;
			state.eventsBound = true;

			document.addEventListener("mizuki:page:loaded", () => {
				setupLazyLoad();
			});

			window.addEventListener("beforeunload", cleanup);
		}

		bindEvents();

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () => {
				setupLazyLoad();
				setupSwupHooks();
			});
		} else {
			setupLazyLoad();
			setupSwupHooks();
		}
	})();
</script>

<style>
	.twikoo-container {
		min-height: 200px;
	}
</style>
